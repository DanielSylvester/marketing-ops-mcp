# Meta Ads — one System User token per ad account
# Generate at: business.facebook.com → Business Settings → System Users → Generate New Token
# Required scopes: ads_read, ads_management, leads_retrieval
META_SMARTWORKS_TOKEN=
META_WORKSTUDIO_TOKEN=

# Meta Ad account IDs (with the act_ prefix)
META_SMARTWORKS_ACCOUNT_ID=act_796980188188098
META_WORKSTUDIO_ACCOUNT_ID=act_399862518529760

# Meta Graph API version. Bump every ~12 months.
META_API_VERSION=v25.0

# Google Ads OAuth2 — generate refresh token via the Google Ads OAuth playground
# Each user keeps their own credentials.
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_CUSTOMER_ID=

# Turso — shared audit log DB (same DB adpilot uses)
# If unset, audit logging is skipped best-effort.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Mutation safety gate.
# dry_run defaults to true on all mutation tools. To actually execute mutations,
# pass dry_run: false AND set this to 1.
MARKETING_OPS_MCP_EXECUTE=
