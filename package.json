{
  "name": "marketing-ops-mcp",
  "version": "0.1.0",
  "description": "MCP server for Meta Ads + Google Ads — read insights, audit creatives, manage negatives.",
  "type": "module",
  "bin": {
    "marketing-ops-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit && eslint src/**/*.ts tests/**/*.ts",
    "format": "prettier --write src/**/*.ts tests/**/*.ts",
    "format:check": "prettier --check src/**/*.ts tests/**/*.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --test --import tsx --import ./tests/_setup.ts tests/*.test.ts",
    "test:stress": "node scripts/stress-test.js"
  },
  "dependencies": {
    "@libsql/client": "^0.17.3",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "zod": "^3.23.0",
    "zod-to-json-schema": "^3.23.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.60.0"
  },
  "engines": {
    "node": ">=20"
  }
}
